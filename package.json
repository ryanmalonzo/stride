{
	"name": "stride",
	"private": true,
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"scripts": {
		"dev": "concurrently \"bun run dev:api\" \"bun run dev:web\"",
		"dev:web": "bun --filter @stride/web dev",
		"dev:api": "bun --filter @stride/api dev",
		"db:generate": "bun --filter @stride/api db:generate",
		"db:migrate": "cd apps/api && bunx --bun prisma migrate dev",
		"setup": "bun install && bun run db:migrate && bun run db:generate",
		"prepare": "husky"
	},
	"lint-staged": {
		"*.{js,ts,jsx,tsx,json,css}": "biome check --write --no-errors-on-unmatched --files-ignore-unknown=true"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.6",
		"concurrently": "^9.2.1",
		"husky": "^9.1.7",
		"lint-staged": "^16.3.2"
	}
}
